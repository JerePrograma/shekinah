{
  "name": "shekinah",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "node scripts/wordpress-reference/serve.mjs --root reference-snapshot/site --host 127.0.0.1 --port 4321",
    "dev:astro": "astro dev",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check . --end-of-line auto",
    "install:browsers": "playwright install chromium",
    "install:browsers:ci": "playwright install --with-deps chromium",
    "capture:wordpress": "node scripts/wordpress-reference/capture.mjs",
    "migrate:wordpress": "pwsh -NoProfile -File scripts/Run-FullMigration.ps1",
    "migrate:wordpress:legacy": "pwsh -NoProfile -File scripts/Migrate-WordPressReference.ps1",
    "verify:snapshot": "node scripts/wordpress-reference/verify.mjs --required && npm run validate:snapshot-content",
    "verify:snapshot:required": "node scripts/wordpress-reference/verify.mjs --required && npm run validate:snapshot-content",
    "verify:snapshot:optional": "node scripts/wordpress-reference/verify.mjs",
    "build": "node scripts/wordpress-reference/build.mjs",
    "preview": "node scripts/wordpress-reference/serve.mjs --root dist",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:powershell": "pwsh -NoLogo -NoProfile -File tests/powershell/migration-tools.smoke.ps1",
    "test:e2e": "playwright test",
    "test:fidelity": "playwright test -c playwright.fidelity.config.ts",
    "audit:output": "node scripts/audit-output.mjs",
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "verify": "npm run check && npm run lint && npm run format:check && npm run verify:snapshot:required && npm run build && npm run test:unit && npm run test:powershell && npm run test:e2e && npm run audit:output && npm run audit:secrets",
    "deploy": "npm run verify && node scripts/deploy-cloudflare.mjs",
    "validate:wordpress-source": "node scripts/wordpress-reference/validate-source.mjs",
    "validate:snapshot-content": "node scripts/wordpress-reference/validate-snapshot-content.mjs",
    "validate:remote": "node scripts/wordpress-reference/validate-remote.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@typescript-eslint/parser": "8.65.0",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "wrangler": "4.112.0"
  },
  "description": "Sitio estático oficial de Shekinah."
}
