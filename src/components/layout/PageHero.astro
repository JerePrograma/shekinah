---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const { eyebrow, title, description, image, imageAlt = '' } = Astro.props;
---

<section class:list={['page-hero', { 'page-hero--with-image': image }]}>
  <div class="container page-hero__grid">
    <div>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {description && <p class="lead">{description}</p>}
      <slot />
    </div>
    {
      image && (
        <img
          class="page-hero__image"
          src={image}
          alt={imageAlt}
          width="1600"
          height="900"
          fetchpriority="high"
        />
      )
    }
  </div>
</section>

<style>
  .page-hero {
    padding-block: clamp(3.5rem, 8vw, 7rem);
    background:
      linear-gradient(115deg, rgb(246 240 228 / 0.97), rgb(255 253 248 / 0.88)),
      url('/images/about-spice-shop.webp') center / cover;
  }

  .page-hero__grid {
    display: grid;
    gap: var(--space-7);
    align-items: center;
  }

  .page-hero--with-image .page-hero__grid {
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.9fr);
  }

  .page-hero__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    object-fit: cover;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 52rem) {
    .page-hero--with-image .page-hero__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
