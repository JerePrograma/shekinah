---
interface Props {
  href: string;
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  meta?: string;
}

const { href, title, description, image, imageAlt, meta } = Astro.props;
---

<article class="card content-card">
  <a class="content-card__image-link" href={href} tabindex="-1" aria-hidden="true">
    <img class="card__media" src={image} alt={imageAlt} width="1200" height="750" loading="lazy" />
  </a>
  <div class="card__body">
    {meta && <p class="card__meta">{meta}</p>}
    <h2><a href={href}>{title}</a></h2>
    <p>{description}</p>
    <a class="content-card__more" href={href}>Leer más <span aria-hidden="true">→</span></a>
  </div>
</article>

<style>
  .content-card {
    height: 100%;
  }

  .content-card__image-link {
    display: block;
    overflow: hidden;
  }

  .content-card__image-link img {
    transition: transform 260ms ease;
  }

  .content-card:hover .content-card__image-link img {
    transform: scale(1.03);
  }

  .content-card h2 {
    font-size: 1.55rem;
  }

  .content-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .content-card__more {
    font-weight: 800;
  }
</style>
