---
import Footer from '@/components/navigation/Footer.astro';
import Header from '@/components/navigation/Header.astro';
import SeoHead from '@/components/seo/SeoHead.astro';
import { site } from '@/data/site';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string | undefined;
  type?: 'website' | 'article' | undefined;
  publishedAt?: Date | undefined;
  updatedAt?: Date | undefined;
  noindex?: boolean | undefined;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>> | undefined;
}

const {
  title = site.name,
  description = site.description,
  image,
  type,
  publishedAt,
  updatedAt,
  noindex,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#123f37" />
    <link rel="icon" type="image/png" href="/images/brand-emblem.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <SeoHead {title} {description} {image} {type} {publishedAt} {updatedAt} {noindex} {jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
