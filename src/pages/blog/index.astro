---
import { getCollection } from 'astro:content';
import ContentCard from '@/components/cards/ContentCard.astro';
import Breadcrumbs from '@/components/navigation/Breadcrumbs.astro';
import PageHero from '@/components/layout/PageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Blog"
  description="Historias, usos culinarios y contexto cultural de hierbas y especias."
>
  <PageHero
    eyebrow="Guía del viajero"
    title="Blog"
    description="Historias, usos culinarios y contexto cultural para explorar cada ingrediente con más criterio."
    image="/images/about-spice-shop.webp"
    imageAlt="Mapa antiguo acompañado por frascos de especias."
  />
  <section class="section">
    <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Blog' }]} />
    <div class="container grid grid--2">
      {
        posts.map((post) => (
          <ContentCard
            href={`/${post.data.slug}/`}
            title={post.data.title}
            description={post.data.description}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            meta={post.data.publishedAt.toLocaleDateString('es-AR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
