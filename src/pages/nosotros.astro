---
import { getEntry, render } from 'astro:content';
import Breadcrumbs from '@/components/navigation/Breadcrumbs.astro';
import PageHero from '@/components/layout/PageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const page = await getEntry('pages', 'nosotros');
if (!page) throw new Error('No se encontró el contenido de Nosotros.');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <PageHero
    eyebrow="Quiénes somos"
    title={page.data.title}
    description={page.data.description}
    image="/images/about-spice-shop.webp"
    imageAlt="Frente de un local identificado con la marca Shekinah."
  />
  <div class="section">
    <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Nosotros' }]} />
    <article class="reading prose">
      <Content />
      <figure>
        <img
          src="/images/brand-lockup.webp"
          alt="Identidad visual de Shekinah, herbolario y tienda gourmet."
          width="1200"
          height="670"
          loading="lazy"
        />
      </figure>
    </article>
  </div>
</BaseLayout>
