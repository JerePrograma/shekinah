---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página solicitada no existe o fue reemplazada durante la migración."
  noindex={true}
>
  <section class="not-found">
    <div class="container not-found__inner">
      <img src="/images/brand-emblem.png" alt="" width="128" height="126" aria-hidden="true" />
      <div>
        <p class="eyebrow">Error 404</p>
        <h1>Página no encontrada</h1>
        <p class="lead">
          La ruta puede haber cambiado durante la reconstrucción. Volvé al inicio o explorá el
          contenido disponible.
        </p>
        <div class="cluster">
          <a class="button" href="/">Ir al inicio</a>
          <a class="button button--secondary" href="/blog/">Ver el blog</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 65vh;
    display: grid;
    align-items: center;
    padding-block: var(--space-8);
  }

  .not-found__inner {
    display: grid;
    grid-template-columns: minmax(10rem, 18rem) minmax(0, 1fr);
    gap: var(--space-7);
    align-items: center;
  }

  @media (max-width: 42rem) {
    .not-found__inner {
      grid-template-columns: 1fr;
    }

    .not-found__inner img {
      width: 10rem;
    }
  }
</style>
